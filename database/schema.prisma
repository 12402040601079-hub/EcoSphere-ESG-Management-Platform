generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum Role {
  SUPER_ADMIN
  ADMIN
  DEPARTMENT_HEAD
  MANAGER
  EMPLOYEE
}

enum ActivityType {
  FLEET_TRAVEL
  ELECTRICITY
  BUSINESS_TRAVEL
  WASTE
}

enum FuelType {
  DIESEL
  PETROL
  GRID
  AVIATION
  LANDFILL
}

enum Scope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

enum ScoringMethod {
  WEIGHTED_AVERAGE
}

enum RecalcFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum PolicyCategory {
  GOVERNANCE
  ENVIRONMENTAL
  SOCIAL
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
  ENVIRONMENTAL
  GOVERNANCE
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParticipationRole {
  VOLUNTEER
  ORGANIZER
  COORDINATOR
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  OVERDUE
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  ARCHIVED
}

enum TargetType {
  CARBON_REDUCTION
}

enum GoalStatus {
  ON_TRACK
  BEHIND
  ACHIEVED
}

enum RewardStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum NotificationType {
  BADGE_EARNED
  CHALLENGE_COMPLETED
  ISSUE_ASSIGNED
  GENERAL
}

enum CsrStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MetricUnit {
  KM
  KWH
  KG
  LITRE
}

// MODELS

model Organization {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String             @unique @db.VarChar(255)
  industry           String             @db.VarChar(100)
  country            String             @db.VarChar(100)
  logoUrl            String?            @map("logo_url") @db.VarChar(500)
  autoEmissionCalc   Boolean            @default(false) @map("auto_emission_calc")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")

  departments        Department[]
  users              User[]
  emissionFactors    EmissionFactor[]
  esgConfiguration   ESGConfiguration?
  esgPolicies        ESGPolicy[]
  categories         Category[]
  badges             Badge[]
  rewards            Reward[]
  carbonTransactions CarbonTransaction[]
  csrActivities      CSRActivity[]
  complianceIssues   ComplianceIssue[]
  challenges         Challenge[]
  environmentalGoals EnvironmentalGoal[]

  @@map("organizations")
}

model Department {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  parentDepartmentId String?            @map("parent_department_id") @db.Uuid
  name               String             @db.VarChar(255)
  code               String             @unique @db.VarChar(50)
  headUserId         String?            @map("head_user_id") @db.Uuid
  createdAt          DateTime           @default(now()) @map("created_at")

  organization       Organization       @relation(fields: [organizationId], references: [id])
  parentDepartment   Department?        @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[]       @relation("DepartmentHierarchy")
  headUser           User?              @relation("DepartmentHead", fields: [headUserId], references: [id])
  
  users              User[]             @relation("DepartmentUsers")
  carbonTransactions CarbonTransaction[]
  complianceIssues   ComplianceIssue[]
  environmentalGoals EnvironmentalGoal[]
  departmentScores   DepartmentScore[]

  @@map("departments")
}

model User {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                  @map("organization_id") @db.Uuid
  departmentId        String                  @map("department_id") @db.Uuid
  email               String                  @unique @db.VarChar(255)
  passwordHash        String                  @map("password_hash") @db.VarChar(255)
  firstName           String                  @map("first_name") @db.VarChar(100)
  lastName            String                  @map("last_name") @db.VarChar(100)
  role                Role
  avatarUrl           String?                 @map("avatar_url") @db.VarChar(500)
  xpTotal             Int                     @default(0) @map("xp_total")
  pointsBalance       Int                     @default(0) @map("points_balance")
  isActive            Boolean                 @default(true) @map("is_active")
  lastLoginAt         DateTime?               @map("last_login_at")
  createdAt           DateTime                @default(now()) @map("created_at")

  organization        Organization            @relation(fields: [organizationId], references: [id])
  department          Department              @relation("DepartmentUsers", fields: [departmentId], references: [id])
  headOfDepartments   Department[]            @relation("DepartmentHead")

  carbonTransRecords  CarbonTransaction[]     @relation("CarbonTransactionRecorder")
  carbonTransReviews  CarbonTransaction[]     @relation("CarbonTransactionReviewer")
  csrActivities       CSRActivity[]           @relation("CSRActivityCreator")
  employeeParts       EmployeeParticipation[] @relation("EmployeeParticipationUser")
  employeePartsApprov EmployeeParticipation[] @relation("EmployeeParticipationApprover")
  policyAcks          PolicyAcknowledgement[]
  complianceIssuesOwn ComplianceIssue[]       @relation("ComplianceIssueOwner")
  complianceIssuesCre ComplianceIssue[]       @relation("ComplianceIssueCreator")
  challengesCreated   Challenge[]             @relation("ChallengeCreator")
  challengeParts      ChallengeParticipation[]
  userBadges          UserBadge[]
  rewardRedemptions   RewardRedemption[]
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@map("users")
}

model EmissionFactor {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String            @map("organization_id") @db.Uuid
  activityType    ActivityType      @map("activity_type")
  fuelType        FuelType          @map("fuel_type")
  factorValue     Decimal           @map("factor_value") @db.Decimal(10, 4)
  unitNumerator   String            @map("unit_numerator") @db.VarChar(20)
  unitDenominator String            @map("unit_denominator") @db.VarChar(20)
  scope           Scope
  source          String?           @db.VarChar(255)
  effectiveFrom   DateTime          @map("effective_from") @db.Date
  effectiveTo     DateTime?         @map("effective_to") @db.Date

  organization    Organization      @relation(fields: [organizationId], references: [id])
  carbonTrans     CarbonTransaction[]

  @@map("emission_factors")
}

model ESGConfiguration {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String          @unique @map("organization_id") @db.Uuid
  envWeight       Decimal         @map("env_weight") @db.Decimal(3, 2)
  socialWeight    Decimal         @map("social_weight") @db.Decimal(3, 2)
  govWeight       Decimal         @map("gov_weight") @db.Decimal(3, 2)
  scoringMethod   ScoringMethod   @map("scoring_method")
  recalcFrequency RecalcFrequency @map("recalc_frequency")

  organization    Organization    @relation(fields: [organizationId], references: [id])

  @@map("esg_configurations")
}

model ESGPolicy {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String                  @map("organization_id") @db.Uuid
  title                  String                  @db.VarChar(255)
  description            String                  @db.Text
  category               PolicyCategory
  version                String                  @db.VarChar(20)
  documentUrl            String                  @map("document_url") @db.VarChar(500)
  effectiveDate          DateTime                @map("effective_date") @db.Date
  requiresAcknowledgement Boolean                 @default(true) @map("requires_acknowledgement")
  createdAt              DateTime                @default(now()) @map("created_at")

  organization           Organization            @relation(fields: [organizationId], references: [id])
  policyAcks             PolicyAcknowledgement[]

  @@map("esg_policies")
}

model Category {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String        @db.VarChar(100)
  type           CategoryType
  pointsPerHour  Int           @default(5) @map("points_per_hour")
  isActive       Boolean       @default(true) @map("is_active")

  organization   Organization  @relation(fields: [organizationId], references: [id])
  csrActivities  CSRActivity[]
  challenges     Challenge[]

  @@map("categories")
}

model Badge {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(100)
  description    String       @db.VarChar(500)
  iconUrl        String       @map("icon_url") @db.VarChar(500)
  tier           BadgeTier
  unlockRule     Json         @map("unlock_rule")
  xpReward       Int          @default(0) @map("xp_reward")

  organization   Organization @relation(fields: [organizationId], references: [id])
  userBadges     UserBadge[]

  @@map("badges")
}

model Reward {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  name           String             @db.VarChar(255)
  description    String?            @db.Text
  imageUrl       String?            @map("image_url") @db.VarChar(500)
  pointsCost     Int                @map("points_cost")
  stock          Int
  isActive       Boolean            @default(true) @map("is_active")

  organization   Organization       @relation(fields: [organizationId], references: [id])
  redemptions    RewardRedemption[]

  @@map("rewards")
}

model CarbonTransaction {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String         @map("organization_id") @db.Uuid
  departmentId      String         @map("department_id") @db.Uuid
  recordedByUserId  String         @map("recorded_by_user_id") @db.Uuid
  emissionFactorId  String         @map("emission_factor_id") @db.Uuid
  activityType      ActivityType   @map("activity_type")
  fuelType          FuelType       @map("fuel_type")
  quantity          Decimal        @db.Decimal(12, 4)
  unit              MetricUnit
  carbonKg          Decimal        @map("carbon_kg") @db.Decimal(12, 4)
  scope             Scope
  activityDate      DateTime       @map("activity_date") @db.Date
  proofUrl          String?        @map("proof_url") @db.VarChar(500)
  notes             String?        @db.Text
  status            ApprovalStatus @default(PENDING)
  reviewedBy        String?        @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime?      @map("reviewed_at")
  createdAt         DateTime       @default(now()) @map("created_at")

  organization      Organization   @relation(fields: [organizationId], references: [id])
  department        Department     @relation(fields: [departmentId], references: [id])
  recordedByUser    User           @relation("CarbonTransactionRecorder", fields: [recordedByUserId], references: [id])
  emissionFactor    EmissionFactor @relation(fields: [emissionFactorId], references: [id])
  reviewedByUser    User?          @relation("CarbonTransactionReviewer", fields: [reviewedBy], references: [id])

  @@map("carbon_transactions")
}

model CSRActivity {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                  @map("organization_id") @db.Uuid
  categoryId      String                  @map("category_id") @db.Uuid
  title           String                  @db.VarChar(255)
  description     String                  @db.Text
  location        String?                 @db.VarChar(255)
  startDate       DateTime                @map("start_date") @db.Date
  endDate         DateTime                @map("end_date") @db.Date
  maxParticipants Int?                    @map("max_participants")
  status          CsrStatus
  createdBy       String                  @map("created_by") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at")

  organization    Organization            @relation(fields: [organizationId], references: [id])
  category        Category                @relation(fields: [categoryId], references: [id])
  createdByUser   User                    @relation("CSRActivityCreator", fields: [createdBy], references: [id])
  participations  EmployeeParticipation[]

  @@map("csr_activities")
}

model EmployeeParticipation {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  csrActivityId   String         @map("csr_activity_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  hoursContributed Decimal       @map("hours_contributed") @db.Decimal(5, 2)
  role            ParticipationRole
  proofUrl        String?        @map("proof_url") @db.VarChar(500)
  comments        String?        @db.Text
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  approvedBy      String?        @map("approved_by") @db.Uuid
  approvedAt      DateTime?      @map("approved_at")
  xpAwarded       Int            @default(0) @map("xp_awarded")
  createdAt       DateTime       @default(now()) @map("created_at")

  csrActivity     CSRActivity    @relation(fields: [csrActivityId], references: [id])
  user            User           @relation("EmployeeParticipationUser", fields: [userId], references: [id])
  approvedByUser  User?          @relation("EmployeeParticipationApprover", fields: [approvedBy], references: [id])

  @@map("employee_participations")
}

model PolicyAcknowledgement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId        String    @map("policy_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  policyVersion   String    @map("policy_version") @db.VarChar(20)
  acknowledgedAt  DateTime  @default(now()) @map("acknowledged_at")
  ipAddress       String?   @map("ip_address") @db.VarChar(45)

  policy          ESGPolicy @relation(fields: [policyId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@unique([policyId, userId, policyVersion])
  @@map("policy_acknowledgements")
}

model ComplianceIssue {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  departmentId    String       @map("department_id") @db.Uuid
  title           String       @db.VarChar(255)
  description     String       @db.Text
  severity        Severity
  status          IssueStatus  @default(OPEN)
  ownerUserId     String       @map("owner_user_id") @db.Uuid
  dueDate         DateTime     @map("due_date") @db.Date
  resolvedAt      DateTime?    @map("resolved_at")
  createdBy       String       @map("created_by") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  department      Department   @relation(fields: [departmentId], references: [id])
  ownerUser       User         @relation("ComplianceIssueOwner", fields: [ownerUserId], references: [id])
  createdByUser   User         @relation("ComplianceIssueCreator", fields: [createdBy], references: [id])

  @@map("compliance_issues")
}

model Challenge {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                   @map("organization_id") @db.Uuid
  title           String                   @db.VarChar(255)
  description     String                   @db.Text
  categoryId      String                   @map("category_id") @db.Uuid
  targetValue     Decimal                  @map("target_value") @db.Decimal(10, 2)
  targetUnit      String                   @map("target_unit") @db.VarChar(50)
  xpReward        Int                      @map("xp_reward")
  startDate       DateTime                 @map("start_date") @db.Date
  endDate         DateTime                 @map("end_date") @db.Date
  status          ChallengeStatus          @default(DRAFT)
  createdBy       String                   @map("created_by") @db.Uuid
  createdAt       DateTime                 @default(now()) @map("created_at")

  organization    Organization             @relation(fields: [organizationId], references: [id])
  category        Category                 @relation(fields: [categoryId], references: [id])
  createdByUser   User                     @relation("ChallengeCreator", fields: [createdBy], references: [id])
  participations  ChallengeParticipation[]

  @@map("challenges")
}

model ChallengeParticipation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId   String    @map("challenge_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  currentValue  Decimal   @default(0) @map("current_value") @db.Decimal(10, 2)
  proofUrl      String?   @map("proof_url") @db.VarChar(500)
  notes         String?   @db.Text
  isCompleted   Boolean   @default(false) @map("is_completed")
  xpAwarded     Int       @default(0) @map("xp_awarded")
  joinedAt      DateTime  @default(now()) @map("joined_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  challenge     Challenge @relation(fields: [challengeId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@map("challenge_participations")
}

model EnvironmentalGoal {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  departmentId    String?      @map("department_id") @db.Uuid
  title           String       @db.VarChar(255)
  targetType      TargetType   @map("target_type")
  targetValue     Decimal      @map("target_value") @db.Decimal(10, 2)
  baselineValue   Decimal      @map("baseline_value") @db.Decimal(12, 4)
  currentValue    Decimal?     @default(0) @map("current_value") @db.Decimal(12, 4)
  targetYear      Int          @map("target_year")
  status          GoalStatus

  organization    Organization @relation(fields: [organizationId], references: [id])
  department      Department?  @relation(fields: [departmentId], references: [id])

  @@map("environmental_goals")
}

model DepartmentScore {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId       String     @map("department_id") @db.Uuid
  period             String     @db.VarChar(10)
  environmentalScore Decimal    @map("environmental_score") @db.Decimal(5, 2)
  socialScore        Decimal    @map("social_score") @db.Decimal(5, 2)
  governanceScore    Decimal    @map("governance_score") @db.Decimal(5, 2)
  totalScore         Decimal    @map("total_score") @db.Decimal(5, 2)
  calculatedAt       DateTime   @default(now()) @map("calculated_at")

  department         Department @relation(fields: [departmentId], references: [id])

  @@map("department_scores")
}

model UserBadge {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  badgeId    String   @map("badge_id") @db.Uuid
  awardedAt  DateTime @default(now()) @map("awarded_at")

  user       User     @relation(fields: [userId], references: [id])
  badge      Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model RewardRedemption {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  rewardId    String       @map("reward_id") @db.Uuid
  pointsSpent Int          @map("points_spent")
  status      RewardStatus
  redeemedAt  DateTime     @default(now()) @map("redeemed_at")

  user        User         @relation(fields: [userId], references: [id])
  reward      Reward       @relation(fields: [rewardId], references: [id])

  @@map("reward_redemptions")
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  linkUrl   String?          @map("link_url") @db.VarChar(500)
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
